{
  "name": "o11yfleet",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "turbo lint",
    "lint:scripts": "oxlint scripts",
    "lint:type-aware": "oxlint --type-aware --ignore-pattern '.claude/**' --ignore-pattern 'infra/tfstate-worker/**' .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:dev-check": "tsx --test scripts/dev-check.test.ts scripts/with-local-env.test.ts",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --cache --cache-location node_modules/.cache/prettier/.prettier-cache --check .",
    "knip": "knip --no-config-hints --max-issues 31",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "knip": "^6.11.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3",
    "wrangler": "^4.87.0"
  }
}
