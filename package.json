{
  "name": "o11yfleet",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "turbo lint",
    "lint:scripts": "oxlint scripts",
    "lint:prose": "alex \"apps/site/src/pages/marketing/*.tsx\" \"**/*.md\"",
    "lint:type-aware": "oxlint --type-aware --ignore-pattern '.claude/**' --ignore-pattern 'infra/tfstate-worker/**' .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:shell": "bats test/shell/install.bats",
    "test:dev-check": "tsx --test scripts/dev-check.test.ts scripts/with-local-env.test.ts",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --cache --cache-location node_modules/.cache/prettier/.prettier-cache --check .",
    "knip": "knip --no-config-hints --max-issues 31",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "alex": "^11.0.1",
    "bats": "^1.11.0",
    "bats-assert": "^2.2.4",
    "bats-support": "^0.3.0",
    "husky": "^9.1.7",
    "knip": "^6.14.1",
    "oxlint": "^0.18.1",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "^3.5.0",
    "tsx": "^4.22.2",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "wrangler": "^4.92.0",
    "write-good": "^1.0.8"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
