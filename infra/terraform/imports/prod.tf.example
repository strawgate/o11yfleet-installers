# Copy this file to infra/terraform/imports.prod.tf only during a production
# adoption run. imports.*.tf files are gitignored because Terraform evaluates
# import blocks during every plan.
#
# Replace every placeholder before use. Current production IDs live in
# ../CLOUDFLARE_SETUP.md; keep concrete IDs in the untracked copy, not here.
# After applying the import, either delete imports.prod.tf or archive the final
# copy in an internal runbook outside Terraform's active .tf files.

import {
  to = cloudflare_d1_database.fleet
  id = "<cloudflare-account-id>/<d1-database-id>"
}

import {
  to = cloudflare_r2_bucket.configs
  id = "<cloudflare-account-id>/<r2-bucket-name>"
}

import {
  to = cloudflare_queue.events
  id = "<cloudflare-account-id>/<queue-id>"
}

import {
  to = cloudflare_worker.fleet
  id = "<cloudflare-account-id>/<worker-script-name>"
}

import {
  to = cloudflare_workers_cron_trigger.fleet
  id = "<cloudflare-account-id>/<worker-script-name>"
}

import {
  to = cloudflare_worker.site
  id = "<cloudflare-account-id>/<site-worker-script-name>"
}

# Fill these IDs from the Cloudflare dashboard or cf-terraforming before use.

import {
  to = cloudflare_dns_record.api
  id = "<cloudflare-zone-id>/<api-dns-record-id>"
}

import {
  to = cloudflare_workers_route.api
  id = "<cloudflare-zone-id>/<api-worker-route-id>"
}

import {
  to = cloudflare_dns_record.site["site"]
  id = "<cloudflare-zone-id>/<site-dns-record-id>"
}

import {
  to = cloudflare_dns_record.site["app"]
  id = "<cloudflare-zone-id>/<app-dns-record-id>"
}

import {
  to = cloudflare_dns_record.site["admin"]
  id = "<cloudflare-zone-id>/<admin-dns-record-id>"
}

import {
  to = cloudflare_workers_route.site["site"]
  id = "<cloudflare-zone-id>/<site-worker-route-id>"
}

import {
  to = cloudflare_workers_route.site["app"]
  id = "<cloudflare-zone-id>/<app-worker-route-id>"
}

import {
  to = cloudflare_workers_route.site["admin"]
  id = "<cloudflare-zone-id>/<admin-worker-route-id>"
}

import {
  to = cloudflare_queue_consumer.events
  id = "<cloudflare-account-id>/<queue-id>/<queue-consumer-id>"
}
