{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".oxlintrc.json", "package.json", "pnpm-lock.yaml", "tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
