# o11yFleet local development environment variables
# Copy this file to .dev.vars and fill in your values:
#   cp apps/worker/.dev.vars.example apps/worker/.dev.vars

# Required: API secret for bearer token auth (any long random string)
API_SECRET=dev-local-api-secret-1234567890x

# Required: Secret for HMAC-SHA256 signing of enrollment token claims
CLAIM_SECRET=dev-local-claim-secret-12345678x

# Required: local seed accounts used by /auth/seed
# Dev-only placeholders; replace before using any shared or production environment.
SEED_TENANT_USER_EMAIL=demo@o11yfleet.com
SEED_TENANT_USER_PASSWORD=demo-change-me-dev-only
SEED_ADMIN_EMAIL=admin@o11yfleet.com
SEED_ADMIN_PASSWORD=admin-change-me-dev-only

# Optional: AI guidance provider settings
# LLM_PROVIDER=minimax
# MINIMAX_API_KEY=your-minimax-api-key
# LLM_BASE_URL=https://api.minimax.io/v1
# LLM_MODEL=MiniMax-M2.7

# Optional: GitHub social auth. Create these through:
#   http://localhost:8787/auth/github/app-manifest
# GITHUB_APP_CLIENT_ID=your-github-app-client-id
# GITHUB_APP_CLIENT_SECRET=your-github-app-client-secret
# GITHUB_APP_ID=your-github-app-id
# GITHUB_APP_WEBHOOK_SECRET=your-github-app-webhook-secret
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
