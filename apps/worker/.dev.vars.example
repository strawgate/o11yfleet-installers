# o11yFleet local development environment variables
# Copy this file to .dev.vars and fill in your values:
#   cp apps/worker/.dev.vars.example apps/worker/.dev.vars
#
# Placeholder values for the SECRET fields below (anything matching
# `dev-local-*`, `*-change-me-*`, `admin-password`, `demo-password`,
# `*-dev-only*`) are automatically replaced with strong random values
# on first `just dev-up`, or on demand via `just ensure-dev-secrets`.
# Real values you set yourself are preserved.

# Required: deployment-level bearer secret for bootstrap and tenant-scoped automation
O11YFLEET_API_BEARER_SECRET=dev-local-api-secret-1234567890x

# Required: Secret for HMAC-SHA256 signing of enrollment token claims
O11YFLEET_CLAIM_HMAC_SECRET=dev-local-claim-secret-12345678x

# Required: local seed accounts used by /auth/seed
# Dev-only placeholders; replaced automatically before they're used —
# see `scripts/ensure-dev-secrets.ts`.
O11YFLEET_SEED_TENANT_USER_EMAIL=demo@o11yfleet.com
O11YFLEET_SEED_TENANT_USER_PASSWORD=demo-change-me-dev-only
O11YFLEET_SEED_ADMIN_EMAIL=admin@o11yfleet.com
O11YFLEET_SEED_ADMIN_PASSWORD=admin-change-me-dev-only

# Optional: AI guidance provider settings
# AI_GUIDANCE_PROVIDER=minimax
# AI_GUIDANCE_MINIMAX_API_KEY=your-minimax-api-key
# AI_GUIDANCE_BASE_URL=https://api.minimax.io/v1
# AI_GUIDANCE_MODEL=MiniMax-M2.7

# Optional: GitHub social auth. Create these through:
#   http://localhost:8787/auth/github/app-manifest
# GITHUB_APP_CLIENT_ID=your-github-app-client-id
# GITHUB_APP_CLIENT_SECRET=your-github-app-client-secret
# GITHUB_APP_ID=your-github-app-id
# GITHUB_APP_WEBHOOK_SECRET=your-github-app-webhook-secret
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
