{
  "name": "@o11yfleet/cli",
  "version": "0.1.0",
  "description": "CLI for o11yfleet",
  "type": "module",
  "bin": {
    "ofleet": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@o11yfleet/core": "workspace:*",
    "chalk": "^5.3.0",
    "yargs": "^17.7.2",
    "inquirer": "^10.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/yargs": "^17.0.32",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
