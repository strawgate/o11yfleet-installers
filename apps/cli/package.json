{
  "name": "@o11yfleet/cli",
  "version": "0.1.0",
  "description": "CLI for o11yfleet",
  "type": "module",
  "bin": {
    "ofleet": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@o11yfleet/core": "workspace:*",
    "chalk": "^5.6.2",
    "inquirer": "^13.4.2",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.35",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
